{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "sdlc-agents",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-03",
	"compatibility_flags": ["nodejs_compat"],
	"observability": { "enabled": true },
	"rules": [{ "type": "Text", "globs": ["**/*.md"], "fallthrough": true }],

	"workflows": [
		{
			"name": "sdlc-agent-workflow",
			"binding": "SDLC_AGENT_WORKFLOW",
			"class_name": "SdlcAgentWorkflow",
		},
		{
			"name": "revision-workflow",
			"binding": "REVISION_WORKFLOW",
			"class_name": "RevisionWorkflow",
		},
	],

	"containers": [
		{
			"class_name": "Sandbox",
			"image": "./container/Dockerfile",
			"instance_type": "basic",
		},
	],
	"durable_objects": {
		"bindings": [
			{
				"class_name": "Sandbox",
				"name": "SANDBOX",
			},
		],
	},
	"migrations": [
		{
			"new_sqlite_classes": ["Sandbox"],
			"tag": "v1",
		},
	],

	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "sdlc-agents-db",
			"database_id": "a9c6508e-fcb6-4223-bcc7-27258f4f1e93",
		},
	],
	"kv_namespaces": [
		{
			"binding": "CACHE",
			"id": "59714b2a0e4b4daba3d808424dab2533",
		},
	],
	"vars": {
		"LLMOPS_GATEWAY_URL": "https://gateway.llmops.build/v1",
	},
}
